---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Page Not Found — Signario"
  description="This page doesn't exist."
>
  <Nav />

  <main class="pt-32 pb-24 px-6 flex items-center justify-center" style="min-height: 60vh;">
    <div class="max-w-md mx-auto text-center">
      <!-- Pulse wave icon -->
      <div class="flex justify-center mb-8">
        <svg width="48" height="48" viewBox="0 0 32 32" fill="none" class="opacity-40">
          <defs>
            <linearGradient id="404-g" x1="0" y1="0" x2="32" y2="0" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#22d3ee"/>
              <stop offset="100%" stop-color="#6366f1"/>
            </linearGradient>
          </defs>
          <path d="M2 16 Q5 16 7 10 Q9 4 11 16 Q13 28 16 16 Q19 4 21 16 Q23 28 25 10 Q27 4 30 16"
                stroke="url(#404-g)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>

      <p class="text-blue-400 text-sm font-medium uppercase tracking-widest mb-3">404</p>
      <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">Page not found</h1>
      <p class="text-slate-400 leading-relaxed mb-8">
        This page doesn't exist or has been moved.
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-500 text-white font-medium px-6 py-3 rounded-xl transition-colors text-sm"
      >
        Back to home
      </a>
    </div>
  </main>

  <Footer />
</Layout>
