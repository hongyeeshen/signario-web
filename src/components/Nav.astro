---
---
<header class="fixed top-0 inset-x-0 z-50 border-b border-[#1e2d4a]/60 bg-[#080e1a]/80 backdrop-blur-md">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 font-semibold text-white hover:opacity-90 transition-opacity">
      <svg width="24" height="24" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="nav-g" x1="0" y1="0" x2="32" y2="0" gradientUnits="userSpaceOnUse">
            <stop offset="0%" stop-color="#22d3ee"/>
            <stop offset="100%" stop-color="#6366f1"/>
          </linearGradient>
        </defs>
        <path d="M2 16 Q5 16 7 10 Q9 4 11 16 Q13 28 16 16 Q19 4 21 16 Q23 28 25 10 Q27 4 30 16"
              stroke="url(#nav-g)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Signario
    </a>

    <!-- CTA -->
    <a
      href="#waitlist"
      onclick="window.posthog?.capture('cta_clicked', { location: 'nav' })"
      class="bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors"
    >
      Get early access
    </a>
  </div>
</header>
