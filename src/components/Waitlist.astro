<section id="waitlist" class="py-24 px-6 border-t border-[#1e2d4a]">
  <div class="max-w-2xl mx-auto text-center">

    <p class="text-slate-400 text-sm font-medium uppercase tracking-widest mb-8">Get started</p>
    <div class="bg-gradient-to-br from-blue-950/60 to-[#0d1627] border border-blue-800/30 rounded-3xl p-10 sm:p-14">
      <h2 class="text-3xl sm:text-4xl font-bold text-white leading-tight mb-4">
        Your roadmap, finally backed by evidence.
      </h2>
      <p class="text-slate-400 leading-relaxed mb-8">
        Simple self-service setup. No implementation consultant. No 6-week onboarding.
      </p>

      <form id="waitlist-form" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
        <input
          type="email"
          name="email"
          required
          placeholder="you@company.com"
          class="flex-1 bg-[#080e1a] border border-[#1e2d4a] text-white placeholder-slate-600 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-blue-500 transition-colors"
        />
        <button
          type="submit"
          class="bg-blue-600 hover:bg-blue-500 text-white font-medium px-6 py-3 rounded-xl transition-colors text-sm whitespace-nowrap"
        >
          Get early access
        </button>
      </form>

      <div id="waitlist-success" class="hidden mt-6 text-emerald-400 text-sm font-medium">
        You're on the list — we'll be in touch shortly.
      </div>
      <div id="waitlist-error" class="hidden mt-6 text-red-400 text-sm">
        Something went wrong. Please try again.
      </div>

      <p class="text-sm text-slate-400 mt-4">Founder pricing locked for the first 50 teams.</p>
      <p class="text-xs text-slate-400 mt-2">
        By submitting, you agree to our <a href="/privacy" class="underline hover:text-slate-300 transition-colors">Privacy Policy</a>.
      </p>
    </div>

