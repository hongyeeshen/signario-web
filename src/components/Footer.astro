---
---

<footer class="border-t border-[#1e2d4a] py-10 px-6">
  <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-6">

    <!-- Logo + tagline -->
    <div class="flex flex-col items-center sm:items-start gap-1">
      <a href="/" class="flex items-center gap-2 font-semibold text-white hover:opacity-80 transition-opacity text-sm">
        <svg width="18" height="18" viewBox="0 0 32 32" fill="none">
          <defs>
            <linearGradient id="footer-g" x1="0" y1="0" x2="32" y2="0" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#22d3ee"/>
              <stop offset="100%" stop-color="#6366f1"/>
            </linearGradient>
          </defs>
          <path d="M2 16 Q5 16 7 10 Q9 4 11 16 Q13 28 16 16 Q19 4 21 16 Q23 28 25 10 Q27 4 30 16"
                stroke="url(#footer-g)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Signario
      </a>
      <p class="text-slate-400 text-xs">AI feedback management for B2B product teams</p>
    </div>

    <!-- Links -->
    <nav class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-slate-400">
      <a href="/privacy" class="hover:text-slate-300 transition-colors">Privacy Policy</a>
      <a href="/terms" class="hover:text-slate-300 transition-colors">Terms of Service</a>
      <button
        id="cookie-prefs"
        class="hover:text-slate-300 transition-colors cursor-pointer bg-transparent border-none p-0 text-sm text-slate-400"
      >
        Cookie Preferences
      </button>
      <a href="mailto:hello@signario.io" class="hover:text-slate-300 transition-colors">hello@signario.io</a>
      <a
        href="https://www.linkedin.com/company/signario"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-slate-300 transition-colors"
      >
        LinkedIn
      </a>
    </nav>

    <!-- Copyright -->
    <p class="text-slate-400 text-xs">© 2026 Signario. All rights reserved.</p>

  </div>
</footer>

<script is:inline>
  document.getElementById('cookie-prefs').addEventListener('click', function () {
    localStorage.removeItem('cookie_consent');
    const banner = document.getElementById('cookie-banner');
    if (banner) banner.style.display = 'block';
  });
</script>
