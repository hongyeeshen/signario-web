---
const builtFor = [
  'Product Managers at B2B SaaS companies with 10–500 customers',
  'Teams already using Linear, ClickUp, or GitHub Issues for execution',
  'PMs moving from gut-feel to customer-evidence driven decisions',
];
---

<section class="py-20 px-6 border-t border-[#1e2d4a]">
  <div class="max-w-4xl mx-auto">
    <p class="text-center text-slate-500 text-sm font-medium uppercase tracking-widest mb-4">Who it's for</p>
    <h2 class="text-3xl sm:text-4xl font-bold text-white text-center leading-tight mb-12">
      Built for a specific kind of team.
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="bg-gradient-to-br from-blue-950/40 to-[#0d1627] border border-blue-700/30 rounded-2xl p-8">
        <p class="text-xs font-semibold text-blue-400 uppercase tracking-widest mb-6">Built for</p>
        <ul class="space-y-3">
          {builtFor.map((item) => (
            <li class="flex items-start gap-3 text-sm text-slate-300">
              <svg class="w-5 h-5 text-blue-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
              </svg>
              {item}
            </li>
          ))}
        </ul>
      </div>
      <div class="bg-[#0d1627] border border-[#1e2d4a] rounded-2xl p-8">
        <p class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-6">Not for</p>
        <ul class="space-y-3">
          <li class="flex items-start gap-3 text-sm text-slate-400">
            <svg class="w-5 h-5 text-slate-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
            </svg>
            Teams that need a full roadmap platform — try Productboard instead.
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>
