---
const steps = [
  {
    step: '01',
    label: 'Collect',
    body: 'Connect Slack or upload a CSV. Feedback flows in automatically — no manual copy-paste.',
  },
  {
    step: '02',
    label: 'Cluster',
    body: 'AI groups feedback into named insight clusters automatically. Duplicates merge. New items slot into the right cluster instantly.',
  },
  {
    step: '03',
    label: 'Prioritize',
    body: 'See which clusters represent the most ARR, highest frequency, and greatest urgency. Connect HubSpot to enrich requests with customer value — updated live as new feedback arrives.',
  },
  {
    step: '04',
    label: 'Close the loop',
    body: 'When a feature ships, customers who requested it are notified automatically. Your team sees the full journey from request to release.',
  },
];
---

<section class="py-20 px-6 border-t border-[#1e2d4a]">
  <div class="max-w-6xl mx-auto">
    <p class="text-center text-slate-400 text-sm font-medium uppercase tracking-widest mb-4">How Signario works</p>
    <h2 class="text-3xl sm:text-4xl font-bold text-white text-center leading-tight mb-16">
      From scattered feedback to confident decision — in four steps.
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {steps.map((s) => (
        <div class="bg-[#0d1627] border border-[#1e2d4a] rounded-2xl p-6 flex flex-col gap-4">
          <span class="text-xs font-semibold text-blue-400 tracking-widest">{s.step}</span>
          <h3 class="font-semibold text-white text-lg">{s.label}</h3>
          <p class="text-slate-400 text-sm leading-relaxed">{s.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
